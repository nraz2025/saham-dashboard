# Tampal URL Cloudflare tunnel dari VPS awak di sini.
# Contoh: https://chose-pix-original-michel.trycloudflare.com
# PENTING: URL ni berubah setiap kali cloudflared di-restart —
# update value ni dalam Vercel (Settings -> Environment Variables)
# setiap kali tunnel baru dimulakan, lepas tu redeploy.
NEXT_PUBLIC_API_URL=https://your-tunnel-url.trycloudflare.com
